{
  "name": "zerotext",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "plugins/*"
  ],
  "scripts": {
    "build": "tsc --build packages/core packages/compiler packages/flow",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit -p packages/core/tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  },
  "license": "Apache-2.0"
}
